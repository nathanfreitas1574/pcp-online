// ─── METAS OPERACIONAIS ───────────────────────────────────────────────────────
enum MetaTipo {
  OCUPACAO_BOXES
  VOLUME_RECEBIDO
  TMP_MEDIO
  VISTORIAS_DIA
  CAMINHOES_DIA
}

model Meta {
  id        String   @id @default(cuid())
  tipo      MetaTipo
  valor     Float
  mes       Int
  ano       Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tipo, mes, ano])
}

// ─── CHECKLIST DE VISTORIA ────────────────────────────────────────────────────
model ChecklistTemplate {
  id        String   @id @default(cuid())
  nome      String
  descricao String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itens     ChecklistItem[]
  vistorias VistoriaChecklist[]
}

model ChecklistItem {
  id          String   @id @default(cuid())
  templateId  String
  template    ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  pergunta    String
  tipo        String   @default("SIM_NAO")  // SIM_NAO | TEXTO | NUMERO
  obrigatorio Boolean  @default(true)
  bloqueante  Boolean  @default(false)      // resposta NAO bloqueia aprovação
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())

  respostas   VistoriaResposta[]
}

model VistoriaChecklist {
  id           String   @id @default(cuid())
  boxId        String
  box          Box      @relation(fields: [boxId], references: [id])
  templateId   String
  template     ChecklistTemplate @relation(fields: [templateId], references: [id])
  data         DateTime @default(now())
  aprovado     Boolean  @default(true)
  usuarioNome  String?
  observacao   String?
  createdAt    DateTime @default(now())

  respostas    VistoriaResposta[]
}

model VistoriaResposta {
  id           String   @id @default(cuid())
  checklistId  String
  checklist    VistoriaChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  itemId       String
  item         ChecklistItem     @relation(fields: [itemId], references: [id])
  resposta     String            // "SIM" | "NAO" | valor livre
  conforme     Boolean  @default(true)
  observacao   String?
  createdAt    DateTime @default(now())
}

// ─── CUSTO OPERACIONAL ────────────────────────────────────────────────────────
model CustoOperacional {
  id            String    @id @default(cuid())
  data          DateTime
  mes           String    // "2025-06"
  tipo          CustoTipo
  descricao     String
  valor         Float
  armazemId     String?
  armazem       Armazem?  @relation(fields: [armazemId], references: [id])
  criadoPorNome String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── CONTRATOS DE ARMAZENAGEM (TOTVS) ────────────────────────────────────────
model ContratoArmazenagem {
  id            String    @id @default(cuid())
  filial        String    @default("")     // "010101-FERTALVO..." — o nº do contrato
  numero        String                      // se repete entre filiais, por isso a
  ultAlt        String?                      // unicidade é composta (filial+numero)
  descricao     String
  tipoMercado   String?
  dataCtr       DateTime?
  ctrExterno    String?
  codEntidade   String?
  lojEntidade   String?
  clienteNome   String
  codProduto    String?
  desProduto    String
  descTabela    String?   // GENERICA | EMBALAGEM | LACRE | PRODUTO ACABADO
  qtdContratada Float     @default(0)
  safra         String?
  stsAssinatura String    @default("Aberto")
  stsFiscal     String    @default("Aberto")
  stsFinanceiro String    @default("Aberto")
  stsEstoque    String    @default("Aberto")
  modalidade    String?
  centroCusto   String?
  tipoContrato  String?   // classificação na importação: COMPRA | VENDA | ARMAZEM_IND
  ativo         Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([filial, numero])
}

// ─── ESTOQUE CONTÁBIL (Materiais De/Em Terceiros — TOTVS) ────────────────────
// Snapshot do estoque em poder de terceiros. Cada importação substitui o
// conjunto anterior (estado atual). Importado via planilha (casa por cabeçalho).
model EstoqueContabil {
  id          String    @id @default(cuid())
  filial      String?
  produto     String?
  descricao   String?
  armazem     String?
  razaoSocial String?
  docOriginal String
  serieDoc    String?
  dtEmissao   DateTime?
  quantidade  Float     @default(0)
  totalNF     Float     @default(0)
  tes         String?
  tipoDeEm    String?
  saldo       Float     @default(0)
  poderTerc   String?
  sentido     String?   // ENTRADA / SAIDA
  importadoEm DateTime  @default(now())

  @@index([razaoSocial])
  @@index([armazem])
  @@index([docOriginal])
}

// ─── DE-PARA de produtos do estoque contábil ────────────────────────────────
// Mapeia o produto do contábil (código + descrição completa) para a descrição
// abreviada usada na VISTORIA, permitindo comparar físico × contábil por produto.
model EstoqueDePara {
  id                 String   @id @default(cuid())
  codigoProduto      String   @unique
  descricaoOriginal  String
  descricaoAbreviada String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── INDICADORES (PCP / produção / custo — mensal com YTD e total) ──────────
model IndicadorPcp {
  id            String   @id @default(cuid())
  ano           Int
  area          String   @default("PCP")
  indicador     String
  ordem         Int      @default(0)
  meta          Float?
  unidade       String?
  sentidoIdeal  String?            // MAIOR | MENOR
  desdobramento String?
  recursoMedido String
  jan Float @default(0)
  fev Float @default(0)
  mar Float @default(0)
  abr Float @default(0)
  mai Float @default(0)
  jun Float @default(0)
  jul Float @default(0)
  ago Float @default(0)
  set Float @default(0)
  out Float @default(0)
  nov Float @default(0)
  dez Float @default(0)
  obs           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([ano, area, indicador, recursoMedido])
  @@index([ano, area])
}

// ─── CONTROLE DE NOTAS CANCELADAS / NUMERAÇÕES INUTILIZADAS (Balança) ────────
model ControleNota {
  id             String    @id @default(cuid())
  data           DateTime?
  usuario        String?                      // quem lançou (Balança)
  numero         String                       // numeração/romaneio (ex: 15819)
  cliente        String?
  tipo           String    @default("CANCELAMENTO")  // CANCELAMENTO | INUTILIZACAO | EXTEMPORANEO
  codigoOperacao String?                       // "015-CA" | "030-INA"
  descricao      String?
  numeroNF       String?                       // NF cancelada (para validar no contábil)
  motivoErro     String?                       // "ERRO OPERACIONAL" | "ERRO SISTEMA"
  observacao     String?
  alertaContabil Boolean   @default(false)     // NF ainda lançada no contábil (não cancelada)
  criadoPorNome  String?
  filial         String?                       // Matriz / Filial (separação)

  // Fluxo de Validação PCP (todos os tipos): AGUARDANDO → VALIDADO → CANCELADO (após conferir NF)
  statusAprovacao String?  @default("AGUARDANDO")
  validadoPor     String?                       // quem validou (PCP)
  validadoEm      DateTime?
  concluidoEm     DateTime?                      // quando confirmado (NF saiu do contábil)
  procedimentos   String?                        // histórico/observações do procedimento

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tipo])
  @@index([filial])
  @@index([cliente])
  @@index([numero])
  @@index([statusAprovacao])
}

// ─── CONTROLE DE VARREDURA (calcário/varredura — semanal) ────────────────────
model VarreduraSemanal {
  id                  String    @id @default(cuid())
  ano                 Int
  mesNum              Int                          // 1-12 (para ordenar)
  mesLabel            String                       // "JANEIRO 2026"
  semana              String                       // "S2"
  dataSegunda         DateTime?
  medSegundaVarredura Float     @default(0)
  medSegundaCalcario  Float     @default(0)
  dataSexta           DateTime?
  medSextaVarredura   Float     @default(0)
  medSextaCalcario    Float     @default(0)
  expedicaoSemana     Float     @default(0)
  geracaoIntervalo    Float     @default(0)
  geracaoCalcario     Float     @default(0)
  geracaoMP           Float     @default(0)
  houveExpedicao      Boolean   @default(false)
  calcarioFisico      Float     @default(0)
  compraCalcario      Float     @default(0)
  saldoAcumulado      Float     @default(0)
  observacao          String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([ano, semana])
  @@index([ano, mesNum])
}

// ─── CONTROLE DE ADITIVOS (Físico × Contábil — armazém 20) ──────────────────
model AditivoControle {
  id            String   @id @default(cuid())
  cliente       String
  produto       String
  fisico        Float    @default(0)
  contabil      Float    @default(0)
  custoUnitario Float    @default(0)   // R$/un para simular custo de perda
  observacao    String?
  ordem         Int      @default(0)
  atualizadoPor String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([cliente, produto])
}

// ─── COBERTURAS PENDENTES ────────────────────────────────────────────────────
// Produtos descarregados (estão no estoque FÍSICO) mas sem nota fiscal para dar
// entrada no CONTÁBIL. Registra a "cobertura pendente" = gap físico − contábil.
model CoberturaPendente {
  id              String    @id @default(cuid())
  codigoRomaneio  String
  numeroDocumento String?
  placa           String?
  transportadora  String?                          // puxado da Marcação pela placa
  motorista       String?                          // puxado da Marcação pela placa
  produto         String
  cliente         String
  volume          Float     @default(0)
  dataDescarga    DateTime?
  numeroNota      String?
  dataSolicitacao DateTime?
  observacao      String?
  boxCodigo       String?
  status          String    @default("PENDENTE")   // PENDENTE | COBERTO
  resolvidoEm     DateTime?
  criadoPorNome   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([cliente])
  @@index([numeroNota])
}

// ─── MARCAÇÃO DE VEÍCULOS (CARGA/DESCARGA — TOTVS) ───────────────────────────
// As colunas do Excel exportado podem mudar de posição; a importação casa
// por NOME do cabeçalho (normalizado), não por índice. Linka com contrato
// via clienteDestino ←→ ContratoArmazenagem.clienteNome.
model MarcacaoVeiculo {
  id               String    @id @default(cuid())
  numero           String    @unique          // coluna "#" (id da marcação)
  operacao         String?                     // CARGA | DESCARGA
  check            String?
  ordem            String?
  status           String?                     // CHECKOUT, etc.
  dataCheckin      DateTime?
  dataMarcacao     DateTime?
  dataCarregamento DateTime?
  produto          String?
  motorista        String?
  tipoServico      String?
  obsMarcacao      String?
  pedidoCliente    String?
  clienteDestino   String?                     // ← chave de ligação com contrato
  placa            String?
  transportadora   String?
  tipoVeiculo      String?
  cliente          String?                     // nome curto (CIBRA, etc.)
  local            String?
  pesoPrevisto     Float     @default(0)
  pesoFinal        Float     @default(0)
  pesoInicial      Float     @default(0)
  pesoLiquido      Float     @default(0)
  turno            String?
  romaneio         String?
  lote             String?
  ativo            Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([clienteDestino])
  @@index([operacao])
  @@index([dataCarregamento])
}

// ─── CONCILIADOR (Marcação × Romaneio × Estoque Contado) ─────────────────────
// Cada lote = uma rodada de conciliação (upload das 3 planilhas num dia).
model ConciliacaoLote {
  id              String   @id @default(cuid())
  data            DateTime @default(now())
  tolerancia      Float    @default(0)   // legado (maior tolerância usada)
  toleranciaJson  String?                // config por operação × comparação (JSON)
  arquivoMarcacao String?
  arquivoRomaneio String?
  arquivoEstoque  String?
  usuarioNome     String?
  total           Int      @default(0)
  conciliados     Int      @default(0)
  divergentes     Int      @default(0)
  descarga        Int      @default(0)
  carga           Int      @default(0)
  itens           ConciliacaoItem[]
  createdAt       DateTime @default(now())

  @@index([data])
}

model ConciliacaoItem {
  id               String   @id @default(cuid())
  loteId           String
  lote             ConciliacaoLote @relation(fields: [loteId], references: [id], onDelete: Cascade)
  origem           String   // MARCACAO | ESTOQUE
  operacao         String?  // CARGA | DESCARGA
  ordem            String?
  numeroNF         String?
  placa            String?
  cliente          String?
  produto          String?
  produtoRomaneio  String?
  produtoEstoque   String?
  pesoMarcacao     Float?
  pesoRomaneio     Float?
  pesoEstoque      Float?
  difPeso          Float?
  difMarcRom       Float?
  difRomEst        Float?
  presencaMarcacao Boolean  @default(false)
  presencaRomaneio Boolean  @default(false)
  presencaEstoque  Boolean  @default(false)
  stsRomaneio      String?
  armazem          String?
  status           String   // CONCILIADO | DIVERGENTE
  divergencias     String?  // tipos separados por vírgula
  justificativa    String?
  justificadoPor   String?
  justificadoEm    DateTime?
  createdAt        DateTime @default(now())

  @@index([loteId])
  @@index([status])
  @@index([operacao])
}

// ─── CONTROLE DE OCORRÊNCIAS ──────────────────────────────────────────────────
enum OcorrenciaTipo {
  DERRAMAMENTO
  AVARIA
  ACIDENTE
  QUALIDADE
  SEGURANCA
  OUTRO
}

enum OcorrenciaStatus {
  ABERTA
  EM_ANALISE
  ENCERRADA
}

enum OcorrenciaGravidade {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

model Ocorrencia {
  id             String              @id @default(cuid())
  tipo           OcorrenciaTipo
  descricao      String
  local          String?
  boxId          String?
  box            Box?                @relation(fields: [boxId], references: [id])
  foto           String?
  status         OcorrenciaStatus    @default(ABERTA)
  gravidade      OcorrenciaGravidade @default(MEDIA)
  responsavel    String?
  planoAcaoId    String?
  resolucao      String?
  dataFechamento DateTime?
  criadoPorId    String
  criadoPor      User                @relation("ocorrencias", fields: [criadoPorId], references: [id])
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

// ─── CONTROLE DE RECEBIMENTO (programação mensal de descarga — manual) ────────
model RecebimentoControle {
  id               String    @id @default(cuid())
  data             DateTime?                       // data prevista
  ano              Int
  mes              Int                              // 1-12
  semana           Int?                             // semana do ano
  unidade          String?   @default("ROO")
  status           String?   @default("PREVISTO")   // PREVISTO | CONFIRMADO | REALIZADO | CANCELADO
  numeroContrato   String?                          // contrato (auto-preenche cliente/produto)
  cliente          String
  produtoAbreviado String
  tipoProduto      String?                          // GRANEL | EMBALADO
  navio            String?
  origem           String?
  volumeProgramado Float     @default(0)
  cancelado        Float     @default(0)
  adicionado       Float     @default(0)
  obs              String?
  criadoPorNome    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([ano, mes])
  @@index([cliente])
  @@index([unidade])
}

// ─── MOTIVOS DE CANCELAMENTO / INUTILIZAÇÃO (lista padrão — Cadastros) ────────
model MotivoCancelamento {
  id        String   @id @default(cuid())
  descricao String   @unique
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── QUEBRA TÉCNICA (perda técnica de recebimento por contrato) ───────────────
model QuebraTecnica {
  id               String    @id @default(cuid())
  data             DateTime?
  filial           String?                 // ROO | AAR | ...
  contrato         String?
  volumeContrato   Float     @default(0)
  cliente          String?
  produto          String?
  origemNavio      String?                 // origem / navio
  volumeRecebido   Float     @default(0)
  quebraTecnica    Float     @default(0)
  quebraDisponivel Float     @default(0)
  pctQuebra        Float     @default(0)   // % de quebra (0.005 = 0,5%)
  saldoAReceber    Float     @default(0)
  sobra            Float     @default(0)
  quebraFutura     Float     @default(0)
  difBalanca       Float     @default(0)
  statusManual     String?                 // override: ABERTO | EM_ANDAMENTO | FINALIZADO (null = automático)
  obs              String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([data])
  @@index([cliente])
  @@index([produto])
}
