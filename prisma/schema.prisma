  nome        String
  eta         DateTime
  produto     String?
  volumePrev  Float?
  clienteNome String?
  origem      String?
  berco       String?
  status      NaveStatus @default(AGUARDANDO)
  observacao  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  previsoes   PrevisaoRecebimento[]
}

// ─── PREVISÃO DE RECEBIMENTO POR BOX ─────────────────────────────────────────
enum PrevisaoStatus {
  AGUARDANDO
  RECEBENDO
  RECEBIDO
  CANCELADO
}

model PrevisaoRecebimento {
  id            String          @id @default(cuid())
  boxId         String
  naveId        String?
  naveNome      String?
  produto       String
  cliente       String
