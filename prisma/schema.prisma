generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PCP
  LIDER
  AUDITOR
  VIEWER
}

enum StatusLacre {
  FECHADO
  ABERTO
  NAO_CONFORME
}

enum StatusLiberacao {
  BLOQUEADO
  AGUARDANDO_VISTORIA
  LIBERADO
}

// Semáforo de reutilização / uso do box
enum StatusUsoBox {
  LIVRE        // disponível para novo produto
  CONSUMO      // produto saindo — sendo expedido
  PROGRAMADO   // programado para receber produto em breve
  BLOQUEADO    // indisponível por manutenção / problema
}

enum CustoTipo {
  MAO_OBRA
  EQUIPAMENTO
  INSUMO
  MANUTENCAO
  OUTROS
}

enum TipoMovimentacao {
  ENTRADA
  SAIDA
  TRANSFERENCIA
}

enum StatusMovimentacao {
  PROGRAMADA
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  role      Role     @default(VIEWER)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lacres            Lacre[]  @relation("lacresCriados")
  lacresInativados  Lacre[]  @relation("lacresInativados")
  movimentacoes     Movimentacao[]
  inventariosFeitos InventarioItem[]
  auditorias        AuditoriaBox[]
  alertas           Alerta[]
  logs              LogAtividade[]
  twoFactor         TwoFactorConfig?
  planosAcao        PlanoAcao[]
  comentariosPlano  PlanoAcaoComentario[] @relation("comentariosPlano")
  ocorrencias       Ocorrencia[]          @relation("ocorrencias")
}

// ─── ARMAZÉM ─────────────────────────────────────────────────────────────────
model Armazem {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nome      String
  descricao String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boxes     Box[]
  custos    CustoOperacional[]
}

// ─── PLANTA DO ARMAZÉM (layout visual: zonas Área Geral / por cliente) ─────────
model PlantaItem {
  id         String   @id @default(cuid())
  armazemId  String                          // FK solta para Armazem
  produto    String
  cliente    String?                          // null/"" = Área Geral; senão = zona do cliente
  quantidade Float    @default(0)            // sacos/unidades
  ordem      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([armazemId])
}

model PlantaConfig {
  id            String   @id @default(cuid())
  armazemId     String   @unique
  balcaoFechado Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

model Box {
  id               String          @id @default(cuid())
  codigo           String          @unique
  descricao        String
  localizacao      String
  capacidade       Int
  ativo            Boolean         @default(true)
  armazemId        String?
  statusLiberacao  StatusLiberacao @default(LIBERADO)
  motivoBloqueio   String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Semáforo de uso + observação livre
  statusUso      StatusUsoBox    @default(LIVRE)
  obsBox         String?

  armazem        Armazem?             @relation(fields: [armazemId], references: [id])
  produtos       ProdutoBox[]
  lacres         Lacre[]
  auditorias     AuditoriaBox[]
  estoques       Estoque[]
  alertas        Alerta[]
  historico      HistoricoBox[]
  programacoes   ProgramacaoSemanal[]
  qualidades     QualidadeRegistro[]
  ocorrencias    Ocorrencia[]
  previsoes      PrevisaoRecebimento[]
  liberacoes     LiberacaoBox[]
  checklistResp  VistoriaChecklist[]
  medicoes       MedicaoBox[]
}

// ─── MEDIÇÃO FÍSICA DE BOX (INVENTÁRIO) ──────────────────────────────────────
model MedicaoBox {
  id           String   @id @default(cuid())
  boxId        String
  box          Box      @relation(fields: [boxId], references: [id], onDelete: Cascade)
  data         DateTime @default(now())
  volumeAntes  Float    // volume no sistema antes da medição
  volumeMedido Float    // volume constatado fisicamente
  diferenca    Float    @default(0)  // volumeMedido - volumeAntes
  observacao   String?
  usuarioNome  String?
  createdAt    DateTime @default(now())
}

// ─── LIBERAÇÃO DE BOX ─────────────────────────────────────────────────────────
model LiberacaoBox {
  id             String          @id @default(cuid())
  boxId          String
  box            Box             @relation(fields: [boxId], references: [id])
  statusAnterior StatusLiberacao
  statusNovo     StatusLiberacao
  motivo         String?
  usuarioNome    String?
  createdAt      DateTime        @default(now())
}

model Produto {
  id        String   @id @default(cuid())
  codigo    String   @unique
  descricao String
  abreviado String?                    // nome curto p/ exibição / padronização
  unidade   String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boxes             ProdutoBox[]
  estoques          Estoque[]
  inventarioItems   InventarioItem[]
  consignacaoItems  ConsignacaoItem[]
  movimentacaoItems MovimentacaoItem[]
  qualidades        QualidadeRegistro[]
  aliases           ProdutoDePara[]
}

// ─── MAPEAMENTO DE/PARA ───────────────────────────────────────────────────────
model ProdutoDePara {
  id              String   @id @default(cuid())
  descricaoOrigem String
  produtoId       String
  produto         Produto  @relation(fields: [produtoId], references: [id])
  criadoPorNome   String?
  createdAt       DateTime @default(now())

  @@unique([descricaoOrigem])
}

model ProdutoBox {
  id         String  @id @default(cuid())
  boxId      String
  produtoId  String
  quantidade Float
  createdAt  DateTime @default(now())

  box     Box     @relation(fields: [boxId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id])

  @@unique([boxId, produtoId])
}

model Lacre {
  id              String      @id @default(cuid())
  boxId           String
  usuarioId       String?
  data            DateTime    @default(now())
  status          StatusLacre @default(FECHADO)
  codigoLacre     String?
  observacao      String?
  foto            String?
  nomeLacrador    String?
  inativado       Boolean     @default(false)
  inativadoEm     DateTime?
  inativadoPorId  String?
  inativadoPorNome String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  box          Box   @relation(fields: [boxId], references: [id])
  usuario      User? @relation("lacresCriados",   fields: [usuarioId],    references: [id])
  inativadoPor User? @relation("lacresInativados", fields: [inativadoPorId], references: [id])
}

model AuditoriaBox {
  id         String   @id @default(cuid())
  boxId      String
  usuarioId  String
  data       DateTime @default(now())
  observacao String?
  fotos      String[]
  conforme   Boolean  @default(true)
  createdAt  DateTime @default(now())

  box     Box  @relation(fields: [boxId], references: [id])
  usuario User @relation(fields: [usuarioId], references: [id])
}

model Inventario {
  id        String   @id @default(cuid())
  tipo      String
  data      DateTime
  status    String   @default("ABERTO")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itens InventarioItem[]
}

model InventarioItem {
  id           String  @id @default(cuid())
  inventarioId String
  produtoId    String
  usuarioId    String
  boxId        String?
  boxCodigo    String?
  clienteNome  String?
  qtdSistema   Float
  qtdContada   Float
  diferenca    Float   @default(0)
  ajustado     Boolean @default(false)
  createdAt    DateTime @default(now())

  inventario Inventario @relation(fields: [inventarioId], references: [id])
  produto    Produto    @relation(fields: [produtoId], references: [id])
  usuario    User       @relation(fields: [usuarioId], references: [id])
}

model Estoque {
  id               String    @id @default(cuid())
  produtoId        String
  boxId            String
  quantidade       Float
  clienteNome      String?
  navio            String?
  dataRecebimento  DateTime?
  updatedAt        DateTime  @updatedAt

  produto Produto @relation(fields: [produtoId], references: [id])
  box     Box     @relation(fields: [boxId], references: [id])

  @@unique([produtoId, boxId])
}

model Movimentacao {
  id            String             @id @default(cuid())
  usuarioId     String
  tipo          TipoMovimentacao
  status        StatusMovimentacao @default(PROGRAMADA)
  origem        String?
  destino       String?
  dataPrevista  DateTime
  dataRealizada DateTime?
  viagens       Int                @default(1)
  observacao    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  usuario User             @relation(fields: [usuarioId], references: [id])
  itens   MovimentacaoItem[]
}

model MovimentacaoItem {
  id             String   @id @default(cuid())
  movimentacaoId String
  produtoId      String
  quantidade     Float
  createdAt      DateTime @default(now())

  movimentacao Movimentacao @relation(fields: [movimentacaoId], references: [id])
  produto      Produto      @relation(fields: [produtoId], references: [id])
}

model Cliente {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nome      String
  abreviado String?                    // nome curto p/ exibição / padronização
  cnpj      String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consignacoes        Consignacao[]
  contratosDescarga   ContratoDescarga[]
  contratosExpedicao  ContratoExpedicao[]
  quebras             Quebra[]
}

// ─── RECEBIMENTO / DESCARGA ───────────────────────────────────────────────────

model ContratoDescarga {
  id               String    @id @default(cuid())
  numero           String    @unique
  clienteId        String
  produtoDesc      String
  produtoAbreviado String?
  tipoProduto      String?
  navio            String?
  origem           String?
  mes              String?
  semana           Int?
  data             DateTime?
  volProgramado    Float     @default(0)
  volConfirmado    Float     @default(0)
  cancelado        Float     @default(0)
  adicionado       Float     @default(0)
  realizado        Float     @default(0)
  saldo            Float     @default(0)
  status           String    @default("PROGRAMADO")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  cliente      Cliente              @relation(fields: [clienteId], references: [id])
  programacoes DescargaProgramacao[]
  registros    DescargaRegistro[]
}

model DescargaProgramacao {
  id            String   @id @default(cuid())
  contratoId    String
  data          DateTime
  mes           String?
  semana        Int?
  clienteNome   String?
  produto       String?
  armazem       String?
  box           String?
  volume        Float    @default(0)
  seg           Float    @default(0)
  ter           Float    @default(0)
  qua           Float    @default(0)
  qui           Float    @default(0)
  sex           Float    @default(0)
  sab           Float    @default(0)
  realizado     Float    @default(0)
  saldo         Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contrato ContratoDescarga @relation(fields: [contratoId], references: [id])
}

model DescargaRegistro {
  id              String    @id @default(cuid())
  contratoId      String?
  romaneio        String?
  placa           String?
  motorista       String?
  clienteNome     String
  transportadora  String?
  produto         String
  localDescarga   String?
  tipoVeiculo     String?
  origem          String?
  pesoEntrada     Float?
  pesoSaida       Float?
  status          String    @default("REALIZADO")
  turno           String?
  dtPortaria      DateTime?
  dtAgendamento   DateTime?
  dtSaida         DateTime?
  tmpMinutos      Float?
  notaFiscal      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contrato ContratoDescarga? @relation(fields: [contratoId], references: [id])
}

// ─── EXPEDIÇÃO ────────────────────────────────────────────────────────────────

model ContratoExpedicao {
  id               String    @id @default(cuid())
  numero           String
  clienteId        String
  operacao         String?
  linhaProducao    String?                 // MISTURA 1 | MISTURA 2 | BAG MÓVEL | PRODUTO ACABADO | GRANEL
  produtoSistema   String?
  produtoAbreviado String?
  tipoProduto      String?
  mes              String?
  semana           Int?
  data             DateTime?
  volProgramado    Float     @default(0)
  realizado        Float     @default(0)
  saldo            Float     @default(0)
  status           String    @default("ABERTO")   // ABERTO | CONFIRMADO | REALIZADO (status manual do contrato)
  tipoContratoManual String?                       // COMPRA | VENDA | ARMAZEM_IND (sobrepõe o derivado do TOTVS)
  dataInicio       DateTime?                        // início do contrato
  dataFim          DateTime?                        // fim do contrato
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  cliente   Cliente             @relation(fields: [clienteId], references: [id])
  registros ExpedicaoRegistro[]
}

model ExpedicaoRegistro {
  id                String    @id @default(cuid())
  contratoId        String?
  data              DateTime
  mes               String?
  semana            Int?
  clienteNome       String
  produto           String
  linha             String?
  operacao          String?
  turno             String?
  orcado            Float     @default(0)
  forecast          Float     @default(0)
  realizado         Float     @default(0)
  capacidade        Float     @default(0)
  notaFiscal        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  contrato ContratoExpedicao? @relation(fields: [contratoId], references: [id])
}

model ExpedicaoOrcado {
  id         String   @id @default(cuid())
  ano        Int
  mes        Int
  clienteNome String
  orcado     Float    @default(0)
  createdAt  DateTime @default(now())

  @@unique([ano, mes, clienteNome])
}

model ExpedicaoCapacidade {
  id         String   @id @default(cuid())
  ano        Int
  mes        Int
  dia        Int      @default(0)   // dia do mês (grade diária estilo Excel)
  linha      String                 // equipamento: NAVE, BAG MÓVEL, PRODUTO ACABADO, GRANEL, COMPACTADOR
  turno      String   @default("A") // A, B, C
  capacidade Float    @default(0)
  createdAt  DateTime @default(now())

  @@unique([ano, mes, dia, linha, turno])
}

// Observação editável por carregamento realizado (chaveada pelo nº da marcação — estável em reimports)
model ExpedicaoObs {
  id             String   @id @default(cuid())
  marcacaoNumero String   @unique
  observacao     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Dia a Dia (Orçado x Faturado) — linhas VÊM DA MARCAÇÃO; aqui só a camada editável
// chave = ymd|CLIENTE|PRODUTO (agrupa as marcações do mesmo dia/cliente/produto)
model ExpedicaoDiaDia {
  id            String   @id @default(cuid())
  chave         String   @unique
  tipoOperacao  String?                 // override opcional (default vem do contrato/tipoServico)
  operacao      String?                 // override opcional
  linhaProducao String?                 // override opcional (default = "local" da marcação)
  forecast      Float    @default(0)
  turnoA        Float    @default(0)
  turnoB        Float    @default(0)
  turnoC        Float    @default(0)
  obs           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Forecast de volume por cliente/tipo, lançado por DATA (o que o cliente diz que vai fazer)
// tipo: ENVASE | GRANEL | ... — usado p/ puxar o realizado pelo tipo de operação
model ExpedicaoForecast {
  id          String   @id @default(cuid())
  data        DateTime            // dia do forecast (lançamento diário; mensal = dia 1)
  clienteNome String
  tipo        String   @default("ENVASE")
  forecast    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([data, clienteNome, tipo])
}

// ─── BI ESTOQUES ──────────────────────────────────────────────────────────────

model EstoqueSnapshot {
  id            String   @id @default(cuid())
  data          DateTime
  clienteNome   String
  produto       String
  classe        String?
  saldoInicial  Float    @default(0)
  entradas      Float    @default(0)
  saidas        Float    @default(0)
  saldoFinal    Float    @default(0)
  createdAt     DateTime @default(now())

  @@unique([data, clienteNome, produto])
}

model Quebra {
  id              String   @id @default(cuid())
  clienteId       String
  clienteNome     String
  produto         String
  classe          String?
  quebraTotal     Float    @default(0)
  totalNfEmitida  Float    @default(0)
  nfPendente      Float    @default(0)
  data            DateTime
  mes             String?
  notaFiscal      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id])
}

model Insumo {
  id        String   @id @default(cuid())
  codigo    String   @unique
  descricao String
  unidade   String   @default("UN")
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movimentos InsumoMovimento[]
}

model InsumoMovimento {
  id          String   @id @default(cuid())
  insumoId    String
  clienteNome String?
  tipo        String
  quantidade  Float
  data        DateTime
  mes         String?
  createdAt   DateTime @default(now())

  insumo Insumo @relation(fields: [insumoId], references: [id])
}

// ─── VISTORIA ESTOQUE ─────────────────────────────────────────────────────────

model VistoriaBox {
  id            String   @id @default(cuid())
  boxCodigo     String
  boxTipo       String
  data          DateTime
  clienteNome   String?
  produto       String?
  classe        String?
  estoque       Float    @default(0)
  capacidade    Float    @default(0)
  pctOcupacao   Float    @default(0)
  diasEstocado  Int?
  statusBox     String   @default("LIVRE")
  observacao    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([boxCodigo, data])
}

// ─── ALERTAS ──────────────────────────────────────────────────────────────────

enum AlertaTipo {
  BOX_CAPACIDADE_CRITICA
  BOX_CAPACIDADE_ALTA
  LACRE_NAO_CONFORME
  INVENTARIO_DIVERGENCIA
  MOVIMENTACAO_ATRASADA
  ESTOQUE_BAIXO
  NAO_CONFORMIDADE
}

enum AlertaSeveridade {
  CRITICO
  AVISO
  INFO
}

enum AlertaStatus {
  ABERTO
  LIDO
  RESOLVIDO
}

model Alerta {
  id          String           @id @default(cuid())
  tipo        AlertaTipo
  severidade  AlertaSeveridade @default(AVISO)
  status      AlertaStatus     @default(ABERTO)
  titulo      String
  descricao   String
  referencia  String?
  boxId       String?
  usuarioId   String?
  resolvidoPor String?
  resolvidoEm DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  box     Box?  @relation(fields: [boxId], references: [id])
  usuario User? @relation(fields: [usuarioId], references: [id])
}

// ─── LOG DE ATIVIDADES ────────────────────────────────────────────────────────

model LogAtividade {
  id          String   @id @default(cuid())
  usuarioId   String?
  usuarioNome String?
  acao        String
  modulo      String
  descricao   String
  ip          String?
  userAgent   String?
  dispositivo String?
  navegador   String?
  referencia  String?
  createdAt   DateTime @default(now())

  usuario User? @relation(fields: [usuarioId], references: [id])
}

// ─── PROGRAMAÇÃO SEMANAL ──────────────────────────────────────────────────────

model ProgramacaoSemanal {
  id          String   @id @default(cuid())
  ano         Int
  semana      Int
  dataInicio  DateTime
  dataFim     DateTime
  boxId         String?
  boxCodigo     String?
  numeroContrato String?
  clienteNome   String
  produto       String
  dom         Float    @default(0)
  seg         Float    @default(0)
  ter         Float    @default(0)
  qua         Float    @default(0)
  qui         Float    @default(0)
  sex         Float    @default(0)
  sab         Float    @default(0)
  total       Float    @default(0)
  realizado   Float    @default(0)
  tipo        String   @default("RECEBIMENTO")
  turno       String?                 // A | B | C
  ordem       Int      @default(0)   // ordem manual das linhas (arrastar)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  box Box? @relation(fields: [boxId], references: [id])

  @@unique([ano, semana, clienteNome, produto, tipo])
}

// Outras demandas internas da semana (varredura, organização, transferências…)
model DemandaInterna {
  id          String    @id @default(cuid())
  ano         Int
  semana      Int
  cliente     String?                  // legado (não usado na UI atual)
  produto     String?                  // legado
  quantidade  Float     @default(0)
  local       String?                  // box/área (AZ5A, B11…)
  turno1      Boolean   @default(false) // legado
  turno2      Boolean   @default(false) // legado
  turno3      Boolean   @default(false) // legado
  responsavel String?                  // quem toca a ação
  dataInicio  DateTime?                 // início planejado
  dataFim     DateTime?                 // conclusão/prazo
  status      String    @default("PENDENTE") // PENDENTE | EM_ANDAMENTO | CONCLUIDA | CANCELADA
  obs         String?
  createdAt   DateTime  @default(now()) // data de inclusão da ação
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

// ─── PROGRAMAÇÃO DO VIRA (movimentação interna box → box) ─────────────────────
model ViraProgramacao {
  id          String   @id @default(cuid())
  prioridade  Int      @default(0)
  data        DateTime
  clienteNome String?
  produto     String?
  boxOrigem   String?
  boxDestino  String?
  volume      String?                    // "TODO VOLUME DO AZ" ou nº — texto livre
  turno       String?
  obs         String?
  status      String   @default("PROGRAMADO") // PROGRAMADO | EM ANDAMENTO | CONCLUIDO | CANCELADO
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── HISTÓRICO DO BOX ─────────────────────────────────────────────────────────

model HistoricoBox {
  id          String   @id @default(cuid())
  boxId       String
  boxCodigo   String
  acao        String
  produto     String?
  clienteNome String?
  volume      Float?
  pctOcupacao Float?
  usuarioNome String?
  observacao  String?
  createdAt   DateTime @default(now())

  box Box @relation(fields: [boxId], references: [id])
}

// ─── TMP (TEMPO MÉDIO PERMANÊNCIA) ───────────────────────────────────────────

model TmpRegistro {
  id              String    @id @default(cuid())
  placa           String
  motorista       String?
  clienteNome     String
  produto         String?
  localDescarga   String?
  dtEntrada       DateTime
  dtSaida         DateTime?
  tmpMinutos      Float?
  status          String    @default("EM_ANDAMENTO")
